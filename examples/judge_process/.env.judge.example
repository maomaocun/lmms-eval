# Example environment configuration for judge examples
# Copy this file to .env.judge and fill in your actual API keys
#
# WARNING: Never commit .env.judge to git! It contains sensitive API keys.
# This file is just a template showing the required variables.

# =============================================================================
# Required for LLM-as-Judge
# =============================================================================

# Your OpenAI API key (required for cloud LLM judge)
# Get yours at: https://platform.openai.com/api-keys
# For local vLLM/SGLang, this can be a dummy key (e.g., "dummy")
export JUDGE_API_KEY="sk-your-openai-api-key-here"

# Judge model name (optional, defaults shown)
export JUDGE_MODEL="gpt-4o-mini"
# Other cloud options: "gpt-4o", "gpt-4", "gpt-3.5-turbo"
# For local vLLM: use the model name you loaded (e.g., "Qwen2.5-VL-7B-Instruct")

# API base URL (optional, for local or other providers)
export JUDGE_BASE_URL="https://api.openai.com/v1"
# For local vLLM: "http://localhost:8000/v1"
# For local SGLang: "http://localhost:30000/v1"
# For Azure: "https://your-resource.openai.azure.com/"

# =============================================================================
# Optional Settings
# =============================================================================

# Default judging mode
# Options: "rule" | "llm" | "auto"
# - rule: Use rule-based judging only
# - llm: Use LLM judging only
# - auto: Use rule first, then LLM fallback for failures
export JUDGE_MODE="auto"

# Maximum concurrent API calls (for parallel processing)
export JUDGE_MAX_CONCURRENT="8"

# =============================================================================
# Usage
# =============================================================================
#
# 1. Copy this file:
#    cp .env.judge.example .env.judge
#
# 2. Edit .env.judge and add your API key
#
# 3. The run_all_examples.sh script will automatically source .env.judge
#
# 4. Or source manually:
#    source .env.judge
#    bash run_all_examples.sh
#
# 5. Run specific examples with LLM judge:
#    source .env.judge
#    python 02_llm_judge.py
